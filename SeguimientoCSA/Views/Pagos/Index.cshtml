@model List<Pago>

@{
    ViewData["Title"] = "Pagos";
    var total = Model.Sum(p => p.Monto);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0">Registro de Pagos</h5>
        <small class="text-muted">@Model.Count pagos — Total: @total.ToString("C")</small>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Nuevo Pago</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Concepto</th>
                        <th>Proveedor</th>
                        <th>Actividad</th>
                        <th>Monto</th>
                        <th>Fecha</th>
                        <th>Factura</th>
                        <th>Método</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pago in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@pago.Concepto</td>
                            <td>
                                <a asp-controller="Proveedores" asp-action="Details" asp-route-id="@pago.ProveedorId" class="text-decoration-none">
                                    @pago.Proveedor.Nombre
                                </a>
                            </td>
                            <td class="small">
                                @if (pago.Actividad != null)
                                {
                                    <a asp-controller="Actividades" asp-action="Details" asp-route-id="@pago.ActividadId" class="text-decoration-none">
                                        @pago.Actividad.Titulo
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="fw-semibold text-success">@pago.Monto.ToString("C")</td>
                            <td class="small text-muted">@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                            <td class="small">@(pago.NumeroFactura ?? "—")</td>
                            <td class="small">@(pago.MetodoPago ?? "—")</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@pago.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@pago.Id" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar este pago?');">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-light">
                        <td colspan="3" class="fw-bold">Total General</td>
                        <td class="fw-bold text-success">@total.ToString("C")</td>
                        <td colspan="4"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
