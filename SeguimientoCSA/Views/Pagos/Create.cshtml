@model Pago

@{
    var isEdit = Model?.Id > 0;
    ViewData["Title"] = ViewData["Title"] ?? (isEdit ? "Editar Pago" : "Nuevo Pago");
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-@(isEdit ? "pencil" : "plus-circle")"></i> @ViewData["Title"]
            </div>
            <div class="card-body">
                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                    @Html.AntiForgeryToken()
                    @if (isEdit)
                    {
                        <input type="hidden" asp-for="Id" />
                    }

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Concepto" class="form-label">Concepto *</label>
                            <input asp-for="Concepto" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProveedorId" class="form-label">Proveedor *</label>
                            <select asp-for="ProveedorId" asp-items="@(ViewBag.Proveedores as SelectList)" class="form-select" required>
                                <option value="">Seleccionar...</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ActividadId" class="form-label">Actividad Relacionada</label>
                            <select asp-for="ActividadId" asp-items="@(ViewBag.Actividades as SelectList)" class="form-select">
                                <option value="">Sin actividad</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Monto" class="form-label">Monto *</label>
                            <input asp-for="Monto" type="number" step="0.01" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FechaPago" class="form-label">Fecha de Pago *</label>
                            <input asp-for="FechaPago" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MetodoPago" class="form-label">Método de Pago</label>
                            <select asp-for="MetodoPago" class="form-select">
                                <option value="">Seleccionar...</option>
                                <option value="Transferencia">Transferencia</option>
                                <option value="Cheque">Cheque</option>
                                <option value="Efectivo">Efectivo</option>
                                <option value="Tarjeta">Tarjeta</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NumeroFactura" class="form-label">Número de Factura</label>
                            <input asp-for="NumeroFactura" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Comprobante" class="form-label">Comprobante / Referencia</label>
                            <input asp-for="Comprobante" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Notas" class="form-label">Notas</label>
                            <textarea asp-for="Notas" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> @(isEdit ? "Guardar Cambios" : "Registrar Pago")</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
