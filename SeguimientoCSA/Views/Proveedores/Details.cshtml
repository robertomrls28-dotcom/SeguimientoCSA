@model Proveedor

@{
    ViewData["Title"] = Model.Nombre;
}

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-person-badge"></i> Información del Proveedor</span>
                <div class="btn-group btn-group-sm">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i></a>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
                </div>
            </div>
            <div class="card-body">
                <h5>@Model.Nombre</h5>
                <span class="badge bg-primary">@(Model.Especialidad ?? "General")</span>
                @if (Model.Activo)
                {
                    <span class="badge bg-success">Activo</span>
                }
                else
                {
                    <span class="badge bg-secondary">Inactivo</span>
                }

                <hr />
                <div class="row g-2 small">
                    <div class="col-6"><span class="text-muted">Contacto:</span><br />@(Model.Contacto ?? "—")</div>
                    <div class="col-6"><span class="text-muted">Teléfono:</span><br />@(Model.Telefono ?? "—")</div>
                    <div class="col-6"><span class="text-muted">Email:</span><br />@(Model.Email ?? "—")</div>
                    <div class="col-6"><span class="text-muted">RFC:</span><br />@(Model.RFC ?? "—")</div>
                    <div class="col-12"><span class="text-muted">Dirección:</span><br />@(Model.Direccion ?? "—")</div>
                    <div class="col-12"><span class="text-muted">Registrado:</span> @Model.FechaRegistro.ToString("dd/MM/yyyy")</div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Notas))
                {
                    <hr />
                    <div class="small"><span class="text-muted">Notas:</span><br />@Model.Notas</div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-list-check"></i> Actividades (@Model.Actividades.Count)</div>
            <div class="card-body p-0">
                @if (Model.Actividades.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Título</th><th>Categoría</th><th>Estado</th><th>Costo Est.</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var act in Model.Actividades)
                            {
                                <tr>
                                    <td><a asp-controller="Actividades" asp-action="Details" asp-route-id="@act.Id" class="text-decoration-none">@act.Titulo</a></td>
                                    <td><span class="badge" style="background-color:@act.Categoria.ColorHex;">@act.Categoria.Nombre</span></td>
                                    <td>
                                        @switch (act.Estado)
                                        {
                                            case EstadoActividad.Pendiente:
                                                <span class="badge bg-warning text-dark">Pendiente</span>
                                                break;
                                            case EstadoActividad.EnProgreso:
                                                <span class="badge bg-info">En Progreso</span>
                                                break;
                                            case EstadoActividad.Completada:
                                                <span class="badge bg-success">Completada</span>
                                                break;
                                            default:
                                                <span class="badge bg-danger">Cancelada</span>
                                                break;
                                        }
                                    </td>
                                    <td>@(act.CostoEstimado?.ToString("C") ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-3">Sin actividades asignadas.</div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header"><i class="bi bi-cash-stack"></i> Pagos (@Model.Pagos.Count) — Total: @Model.Pagos.Sum(p => p.Monto).ToString("C")</div>
            <div class="card-body p-0">
                @if (Model.Pagos.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Concepto</th><th>Monto</th><th>Fecha</th><th>Factura</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var pago in Model.Pagos.OrderByDescending(p => p.FechaPago))
                            {
                                <tr>
                                    <td class="small">@pago.Concepto</td>
                                    <td class="fw-semibold text-success">@pago.Monto.ToString("C")</td>
                                    <td class="small text-muted">@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                                    <td class="small">@(pago.NumeroFactura ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-3">Sin pagos registrados.</div>
                }
            </div>
        </div>
    </div>
</div>
