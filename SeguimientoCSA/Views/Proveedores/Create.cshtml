@model Proveedor

@{
    var isEdit = Model?.Id > 0;
    ViewData["Title"] = ViewData["Title"] ?? (isEdit ? "Editar Proveedor" : "Nuevo Proveedor");
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-@(isEdit ? "pencil" : "plus-circle")"></i> @ViewData["Title"]
            </div>
            <div class="card-body">
                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                    @Html.AntiForgeryToken()
                    @if (isEdit)
                    {
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="FechaRegistro" />
                    }

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label">Nombre / Razón Social *</label>
                            <input asp-for="Nombre" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Contacto" class="form-label">Persona de Contacto</label>
                            <input asp-for="Contacto" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Especialidad" class="form-label">Especialidad</label>
                            <input asp-for="Especialidad" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RFC" class="form-label">RFC</label>
                            <input asp-for="RFC" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label">Dirección</label>
                            <input asp-for="Direccion" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mt-3">
                                <input asp-for="Activo" class="form-check-input" />
                                <label asp-for="Activo" class="form-check-label">Proveedor Activo</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notas" class="form-label">Notas</label>
                            <textarea asp-for="Notas" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> @(isEdit ? "Guardar Cambios" : "Registrar Proveedor")</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
