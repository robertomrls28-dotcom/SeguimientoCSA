@model Actividad

@{
    ViewData["Title"] = Model.Titulo;
}

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-info-circle"></i> Detalle de Actividad</span>
                <div class="btn-group btn-group-sm">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> Editar</a>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
                </div>
            </div>
            <div class="card-body">
                <h5>@Model.Titulo</h5>
                <p class="text-muted">@(Model.Descripcion ?? "Sin descripción")</p>

                <div class="row g-3 mt-2">
                    <div class="col-md-4">
                        <div class="small text-muted">Estado</div>
                        @switch (Model.Estado)
                        {
                            case EstadoActividad.Pendiente:
                                <span class="badge bg-warning text-dark">Pendiente</span>
                                break;
                            case EstadoActividad.EnProgreso:
                                <span class="badge bg-info">En Progreso</span>
                                break;
                            case EstadoActividad.Completada:
                                <span class="badge bg-success">Completada</span>
                                break;
                            case EstadoActividad.Cancelada:
                                <span class="badge bg-danger">Cancelada</span>
                                break;
                        }
                    </div>
                    <div class="col-md-4">
                        <div class="small text-muted">Categoría</div>
                        <span class="badge" style="background-color:@Model.Categoria.ColorHex;">@Model.Categoria.Nombre</span>
                    </div>
                    <div class="col-md-4">
                        <div class="small text-muted">Prioridad</div>
                        @switch (Model.Prioridad)
                        {
                            case 1:
                                <span class="badge bg-danger">Alta</span>
                                break;
                            case 2:
                                <span class="badge bg-warning text-dark">Media</span>
                                break;
                            default:
                                <span class="badge bg-secondary">Baja</span>
                                break;
                        }
                    </div>
                    <div class="col-md-4">
                        <div class="small text-muted">Fecha Creación</div>
                        <strong>@Model.FechaCreacion.ToString("dd/MM/yyyy")</strong>
                    </div>
                    <div class="col-md-4">
                        <div class="small text-muted">Fecha Inicio</div>
                        <strong>@(Model.FechaInicio?.ToString("dd/MM/yyyy") ?? "—")</strong>
                    </div>
                    <div class="col-md-4">
                        <div class="small text-muted">Fecha Fin</div>
                        <strong>@(Model.FechaFin?.ToString("dd/MM/yyyy") ?? "—")</strong>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Costo Estimado</div>
                        <strong>@(Model.CostoEstimado?.ToString("C") ?? "—")</strong>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Costo Real</div>
                        <strong>@(Model.CostoReal?.ToString("C") ?? "—")</strong>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Observaciones))
                {
                    <div class="mt-3">
                        <div class="small text-muted">Observaciones</div>
                        <p>@Model.Observaciones</p>
                    </div>
                }
            </div>
        </div>

        <!-- Pagos asociados -->
        <div class="card">
            <div class="card-header">
                <i class="bi bi-cash-stack"></i> Pagos Asociados (@Model.Pagos.Count)
            </div>
            <div class="card-body p-0">
                @if (Model.Pagos.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Concepto</th>
                                <th>Proveedor</th>
                                <th>Monto</th>
                                <th>Fecha</th>
                                <th>Factura</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pago in Model.Pagos)
                            {
                                <tr>
                                    <td>@pago.Concepto</td>
                                    <td>@pago.Proveedor.Nombre</td>
                                    <td class="fw-semibold text-success">@pago.Monto.ToString("C")</td>
                                    <td class="small text-muted">@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                                    <td class="small">@(pago.NumeroFactura ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-light">
                                <td colspan="2" class="fw-bold">Total</td>
                                <td class="fw-bold text-success">@Model.Pagos.Sum(p => p.Monto).ToString("C")</td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-3">No hay pagos registrados para esta actividad.</div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-people"></i> Proveedor</div>
            <div class="card-body">
                @if (Model.Proveedor != null)
                {
                    <strong>@Model.Proveedor.Nombre</strong>
                    <div class="small text-muted">@Model.Proveedor.Especialidad</div>
                    <div class="small mt-1"><i class="bi bi-telephone"></i> @(Model.Proveedor.Telefono ?? "—")</div>
                    <div class="small"><i class="bi bi-envelope"></i> @(Model.Proveedor.Email ?? "—")</div>
                }
                else
                {
                    <span class="text-muted">Sin proveedor asignado</span>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header"><i class="bi bi-shield-check"></i> Supervisor</div>
            <div class="card-body">
                @if (Model.Supervisor != null)
                {
                    <strong>@Model.Supervisor.Nombre</strong>
                    <div class="small text-muted">@Model.Supervisor.Cargo</div>
                    <div class="small mt-1"><i class="bi bi-telephone"></i> @(Model.Supervisor.Telefono ?? "—")</div>
                    <div class="small"><i class="bi bi-envelope"></i> @(Model.Supervisor.Email ?? "—")</div>
                }
                else
                {
                    <span class="text-muted">Sin supervisor asignado</span>
                }
            </div>
        </div>
    </div>
</div>
