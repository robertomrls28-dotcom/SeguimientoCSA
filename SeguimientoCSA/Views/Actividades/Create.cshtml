@model Actividad

@{
    ViewData["Title"] = ViewData["Title"] ?? "Nueva Actividad";
    var isEdit = Model?.Id > 0;
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-@(isEdit ? "pencil" : "plus-circle")"></i> @ViewData["Title"]
            </div>
            <div class="card-body">
                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                    @Html.AntiForgeryToken()
                    @if (isEdit)
                    {
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="FechaCreacion" />
                    }

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Titulo" class="form-label">Título *</label>
                            <input asp-for="Titulo" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoriaId" class="form-label">Categoría *</label>
                            <select asp-for="CategoriaId" asp-items="@(ViewBag.Categorias as SelectList)" class="form-select" required>
                                <option value="">Seleccionar...</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Estado" class="form-label">Estado</label>
                            <select asp-for="Estado" asp-items="Html.GetEnumSelectList<EstadoActividad>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Prioridad" class="form-label">Prioridad</label>
                            <select asp-for="Prioridad" class="form-select">
                                <option value="1">Alta</option>
                                <option value="2">Media</option>
                                <option value="3">Baja</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FechaInicio" class="form-label">Fecha Inicio</label>
                            <input asp-for="FechaInicio" type="date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FechaFin" class="form-label">Fecha Fin</label>
                            <input asp-for="FechaFin" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProveedorId" class="form-label">Proveedor</label>
                            <select asp-for="ProveedorId" asp-items="@(ViewBag.Proveedores as SelectList)" class="form-select">
                                <option value="">Sin asignar</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SupervisorId" class="form-label">Supervisor (Comité)</label>
                            <select asp-for="SupervisorId" asp-items="@(ViewBag.Supervisores as SelectList)" class="form-select">
                                <option value="">Sin asignar</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CostoEstimado" class="form-label">Costo Estimado</label>
                            <input asp-for="CostoEstimado" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CostoReal" class="form-label">Costo Real</label>
                            <input asp-for="CostoReal" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Observaciones" class="form-label">Observaciones</label>
                            <textarea asp-for="Observaciones" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CreadoPor" class="form-label">Creado Por</label>
                            <input asp-for="CreadoPor" class="form-control" />
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> @(isEdit ? "Guardar Cambios" : "Crear Actividad")</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
