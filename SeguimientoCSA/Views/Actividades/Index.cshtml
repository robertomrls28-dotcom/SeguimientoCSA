@model List<Actividad>

@{
    ViewData["Title"] = "Actividades";
    var categorias = ViewBag.Categorias as List<CategoriaActividad>;
    var estadoFiltro = ViewBag.EstadoFiltro as EstadoActividad?;
    var categoriaFiltro = ViewBag.CategoriaFiltro as int?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0">Listado de Actividades</h5>
        <small class="text-muted">@Model.Count actividades encontradas</small>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Nueva Actividad</a>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small mb-0">Estado</label>
                <select name="estado" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    <option value="@EstadoActividad.Pendiente" selected="@(estadoFiltro == EstadoActividad.Pendiente)">Pendiente</option>
                    <option value="@EstadoActividad.EnProgreso" selected="@(estadoFiltro == EstadoActividad.EnProgreso)">En Progreso</option>
                    <option value="@EstadoActividad.Completada" selected="@(estadoFiltro == EstadoActividad.Completada)">Completada</option>
                    <option value="@EstadoActividad.Cancelada" selected="@(estadoFiltro == EstadoActividad.Cancelada)">Cancelada</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small mb-0">Categoría</label>
                <select name="categoriaId" class="form-select form-select-sm">
                    <option value="">Todas</option>
                    @if (categorias != null)
                    {
                        @foreach (var cat in categorias)
                        {
                            <option value="@cat.Id" selected="@(categoriaFiltro == cat.Id)">@cat.Nombre</option>
                        }
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-filter"></i> Filtrar</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Limpiar</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Título</th>
                        <th>Categoría</th>
                        <th>Estado</th>
                        <th>Prioridad</th>
                        <th>Proveedor</th>
                        <th>Supervisor</th>
                        <th>Costo Est.</th>
                        <th>Fecha Inicial</th>
                        <th>Vencido</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var act in Model)
                    {
                        var diasVencidos = 0;
                        var mostrarVencido = false;

                        if (act.FechaFin.HasValue
                            && act.Estado != EstadoActividad.Completada
                            && act.Estado != EstadoActividad.Cancelada)
                        {
                            diasVencidos = (int)(DateTime.Today - act.FechaFin.Value.Date).TotalDays;
                            mostrarVencido = diasVencidos > 0;
                        }

                        <tr>
                            <td>
                                <a asp-action="Details" asp-route-id="@act.Id" class="text-decoration-none fw-semibold">@act.Titulo</a>
                            </td>
                            <td><span class="badge" style="background-color:@act.Categoria.ColorHex;">@act.Categoria.Nombre</span></td>
                            <td>
                                @switch (act.Estado)
                                {
                                    case EstadoActividad.Pendiente:
                                        <span class="badge bg-warning text-dark">Pendiente</span>
                                        break;
                                    case EstadoActividad.EnProgreso:
                                        <span class="badge bg-info">En Progreso</span>
                                        break;
                                    case EstadoActividad.Completada:
                                        <span class="badge bg-success">Completada</span>
                                        break;
                                    case EstadoActividad.Cancelada:
                                        <span class="badge bg-danger">Cancelada</span>
                                        break;
                                }
                            </td>
                            <td>
                                @switch (act.Prioridad)
                                {
                                    case 1:
                                        <span class="badge bg-danger">Alta</span>
                                        break;
                                    case 2:
                                        <span class="badge bg-warning text-dark">Media</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">Baja</span>
                                        break;
                                }
                            </td>
                            <td class="small">@(act.Proveedor?.Nombre ?? "—")</td>
                            <td class="small">@(act.Supervisor?.Nombre ?? "—")</td>
                            <td>@(act.CostoEstimado?.ToString("C") ?? "—")</td>
                            <td class="text-muted small">@((act.FechaInicio ?? act.FechaCreacion).ToString("dd/MM/yy"))</td>
                            <td>
                                @if (act.Estado == EstadoActividad.Completada)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Cerrada</span>
                                }
                                else if (act.Estado == EstadoActividad.Cancelada)
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> Cancelada</span>
                                }
                                else if (!act.FechaFin.HasValue)
                                {
                                    <span class="text-muted small">—</span>
                                }
                                else if (mostrarVencido)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> @diasVencidos día(s)</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="bi bi-clock"></i> En tiempo</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@act.Id" class="btn btn-outline-primary" title="Editar"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@act.Id" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar esta actividad?');">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-outline-danger btn-sm" title="Eliminar"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
