@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col">
        <div class="card stat-card" style="border-left-color: #0d6efd;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small text-uppercase">Total Actividades</div>
                    <h3 class="mb-0">@Model.TotalActividades</h3>
                </div>
                <i class="bi bi-list-check stat-icon text-primary"></i>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card" style="border-left-color: #ffc107;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small text-uppercase">Pendientes</div>
                    <h3 class="mb-0">@Model.ActividadesPendientes</h3>
                </div>
                <i class="bi bi-clock stat-icon text-warning"></i>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card" style="border-left-color: #17a2b8;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small text-uppercase">En Progreso</div>
                    <h3 class="mb-0">@Model.ActividadesEnProgreso</h3>
                </div>
                <i class="bi bi-arrow-repeat stat-icon text-info"></i>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card" style="border-left-color: #dc3545;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small text-uppercase">Vencidas</div>
                    <h3 class="mb-0">@Model.ActividadesVencidas</h3>
                </div>
                <i class="bi bi-exclamation-triangle stat-icon text-danger"></i>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card" style="border-left-color: #198754;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small text-uppercase">Completadas</div>
                    <h3 class="mb-0">@Model.ActividadesCompletadas</h3>
                </div>
                <i class="bi bi-check-circle stat-icon text-success"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card stat-card" style="border-left-color: #6f42c1;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small text-uppercase">Proveedores Activos</div>
                    <h3 class="mb-0">@Model.TotalProveedores</h3>
                </div>
                <i class="bi bi-people stat-icon text-purple" style="color:#6f42c1;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card" style="border-left-color: #dc3545;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small text-uppercase">Miembros Comité</div>
                    <h3 class="mb-0">@Model.TotalMiembrosComite</h3>
                </div>
                <i class="bi bi-shield-check stat-icon text-danger"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card" style="border-left-color: #20c997;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small text-uppercase">Total Pagos</div>
                    <h3 class="mb-0">@Model.TotalPagos.ToString("C")</h3>
                </div>
                <i class="bi bi-cash-stack stat-icon" style="color:#20c997;"></i>
            </div>
        </div>
    </div>
</div>

<!-- Tables -->
<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-list-check"></i> Actividades Recientes</span>
                <a asp-controller="Actividades" asp-action="Index" class="btn btn-sm btn-outline-primary">Ver todas</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                                 <tr>
                                    <th>Actividad</th>
                                    <th>Categoría</th>
                                    <th>Estado</th>
                                    <th>Prioridad</th>
                                    <th>Fecha Inicial</th>
                                    <th>Vencido</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var act in Model.ActividadesRecientes)
                                {
                                    var diasVencidos = 0;
                                    var mostrarVencido = false;

                                    if (act.FechaFin.HasValue
                                        && act.Estado != EstadoActividad.Completada
                                        && act.Estado != EstadoActividad.Cancelada)
                                    {
                                        diasVencidos = (int)(DateTime.Today - act.FechaFin.Value.Date).TotalDays;
                                        mostrarVencido = diasVencidos > 0;
                                    }

                                    <tr>
                                        <td>
                                            <a asp-controller="Actividades" asp-action="Details" asp-route-id="@act.Id" class="text-decoration-none fw-semibold">
                                                @act.Titulo
                                            </a>
                                        </td>
                                        <td><span class="badge" style="background-color:@act.Categoria.ColorHex;">@act.Categoria.Nombre</span></td>
                                        <td>
                                            @switch (act.Estado)
                                            {
                                                case EstadoActividad.Pendiente:
                                                    <span class="badge bg-warning text-dark badge-estado">Pendiente</span>
                                                    break;
                                                case EstadoActividad.EnProgreso:
                                                    <span class="badge bg-info badge-estado">En Progreso</span>
                                                    break;
                                                case EstadoActividad.Completada:
                                                    <span class="badge bg-success badge-estado">Completada</span>
                                                    break;
                                                case EstadoActividad.Cancelada:
                                                    <span class="badge bg-danger badge-estado">Cancelada</span>
                                                    break;
                                            }
                                        </td>
                                        <td>
                                            @switch (act.Prioridad)
                                            {
                                                case 1:
                                                    <span class="badge bg-danger">Alta</span>
                                                    break;
                                                case 2:
                                                    <span class="badge bg-warning text-dark">Media</span>
                                                    break;
                                                case 3:
                                                    <span class="badge bg-secondary">Baja</span>
                                                    break;
                                            }
                                        </td>
                                        <td class="text-muted small">@((act.FechaInicio ?? act.FechaCreacion).ToString("dd/MM/yyyy"))</td>
                                        <td>
                                            @if (act.Estado == EstadoActividad.Completada)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Cerrada</span>
                                            }
                                            else if (act.Estado == EstadoActividad.Cancelada)
                                            {
                                                <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> Cancelada</span>
                                            }
                                            else if (!act.FechaFin.HasValue)
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                            else if (mostrarVencido)
                                            {
                                                <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> @diasVencidos día(s)</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success"><i class="bi bi-clock"></i> En tiempo</span>
                                            }
                                        </td>
                                    </tr>
                                }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-cash-stack"></i> Últimos Pagos</span>
                <a asp-controller="Pagos" asp-action="Index" class="btn btn-sm btn-outline-primary">Ver todos</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Concepto</th>
                                <th>Proveedor</th>
                                <th>Monto</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pago in Model.PagosRecientes)
                            {
                                <tr>
                                    <td class="small">@pago.Concepto</td>
                                    <td class="small">@pago.Proveedor.Nombre</td>
                                    <td class="fw-semibold text-success">@pago.Monto.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
