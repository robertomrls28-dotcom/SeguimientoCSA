@model ReporteViewModel

@{
    ViewData["Title"] = "Reportes";
}

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-funnel"></i> Filtros de Reporte</div>
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">Fecha Inicio</label>
                <input type="date" name="fechaInicio" class="form-control form-control-sm" value="@Model.FechaInicio?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Fecha Fin</label>
                <input type="date" name="fechaFin" class="form-control form-control-sm" value="@Model.FechaFin?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Categoría</label>
                <select name="categoriaId" class="form-select form-select-sm">
                    <option value="">Todas</option>
                    @foreach (var cat in Model.Categorias)
                    {
                        <option value="@cat.Id" selected="@(Model.CategoriaId == cat.Id)">@cat.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Proveedor</label>
                <select name="proveedorId" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    @foreach (var prov in Model.Proveedores)
                    {
                        <option value="@prov.Id" selected="@(Model.ProveedorId == prov.Id)">@prov.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Estado</label>
                <select name="estado" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    <option value="@EstadoActividad.Pendiente" selected="@(Model.Estado == EstadoActividad.Pendiente)">Pendiente</option>
                    <option value="@EstadoActividad.EnProgreso" selected="@(Model.Estado == EstadoActividad.EnProgreso)">En Progreso</option>
                    <option value="@EstadoActividad.Completada" selected="@(Model.Estado == EstadoActividad.Completada)">Completada</option>
                    <option value="@EstadoActividad.Cancelada" selected="@(Model.Estado == EstadoActividad.Cancelada)">Cancelada</option>
                </select>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Generar Reporte</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Limpiar Filtros</a>
            </div>
        </form>
    </div>
</div>

<!-- Resumen -->
<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Actividades</div>
                <h4 class="mb-0">@Model.Actividades.Count</h4>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Completadas</div>
                <h4 class="mb-0 text-success">@Model.TotalActividadesCompletadas</h4>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Pendientes</div>
                <h4 class="mb-0 text-warning">@Model.TotalActividadesPendientes</h4>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Costo Estimado</div>
                <h6 class="mb-0">@Model.TotalCostoEstimado.ToString("C")</h6>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Costo Real</div>
                <h6 class="mb-0">@Model.TotalCostoReal.ToString("C")</h6>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Total Pagos</div>
                <h6 class="mb-0 text-success">@Model.TotalPagos.ToString("C")</h6>
            </div>
        </div>
    </div>
</div>

<!-- Tabla de Actividades -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-list-check"></i> Actividades (@Model.Actividades.Count)</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Título</th>
                        <th>Categoría</th>
                        <th>Estado</th>
                        <th>Proveedor</th>
                        <th>Supervisor</th>
                        <th>Costo Est.</th>
                        <th>Costo Real</th>
                        <th>Creación</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var act in Model.Actividades)
                    {
                        <tr>
                            <td><a asp-controller="Actividades" asp-action="Details" asp-route-id="@act.Id" class="text-decoration-none">@act.Titulo</a></td>
                            <td><span class="badge" style="background-color:@act.Categoria.ColorHex;">@act.Categoria.Nombre</span></td>
                            <td>
                                @switch (act.Estado)
                                {
                                    case EstadoActividad.Pendiente:
                                        <span class="badge bg-warning text-dark">Pendiente</span>
                                        break;
                                    case EstadoActividad.EnProgreso:
                                        <span class="badge bg-info">En Progreso</span>
                                        break;
                                    case EstadoActividad.Completada:
                                        <span class="badge bg-success">Completada</span>
                                        break;
                                    default:
                                        <span class="badge bg-danger">Cancelada</span>
                                        break;
                                }
                            </td>
                            <td class="small">@(act.Proveedor?.Nombre ?? "—")</td>
                            <td class="small">@(act.Supervisor?.Nombre ?? "—")</td>
                            <td>@(act.CostoEstimado?.ToString("C") ?? "—")</td>
                            <td>@(act.CostoReal?.ToString("C") ?? "—")</td>
                            <td class="small text-muted">@act.FechaCreacion.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Tabla de Pagos -->
<div class="card">
    <div class="card-header"><i class="bi bi-cash-stack"></i> Pagos (@Model.Pagos.Count) — Total: @Model.TotalPagos.ToString("C")</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Concepto</th>
                        <th>Proveedor</th>
                        <th>Actividad</th>
                        <th>Monto</th>
                        <th>Fecha</th>
                        <th>Factura</th>
                        <th>Método</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pago in Model.Pagos)
                    {
                        <tr>
                            <td>@pago.Concepto</td>
                            <td class="small">@pago.Proveedor.Nombre</td>
                            <td class="small">@(pago.Actividad?.Titulo ?? "—")</td>
                            <td class="fw-semibold text-success">@pago.Monto.ToString("C")</td>
                            <td class="small text-muted">@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                            <td class="small">@(pago.NumeroFactura ?? "—")</td>
                            <td class="small">@(pago.MetodoPago ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
