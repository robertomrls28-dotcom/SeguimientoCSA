@model List<MiembroComite>

@{
    ViewData["Title"] = "Comité de Vigilancia";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0">Comité de Vigilancia</h5>
        <small class="text-muted">@Model.Count miembros registrados</small>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Nuevo Miembro</a>
</div>

<div class="row g-3">
    @foreach (var miembro in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:48px;height:48px;font-size:1.2rem;flex-shrink:0;">
                            @miembro.Nombre[0]
                        </div>
                        <div>
                            <h6 class="mb-0">
                                <a asp-action="Details" asp-route-id="@miembro.Id" class="text-decoration-none">@miembro.Nombre</a>
                            </h6>
                            <span class="badge bg-dark">@miembro.Cargo</span>
                            @if (miembro.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </div>
                    </div>
                    <div class="mt-2 small">
                        @if (!string.IsNullOrEmpty(miembro.NumeroDepto))
                        {
                            <div><i class="bi bi-building"></i> Depto. @miembro.NumeroDepto</div>
                        }
                        @if (!string.IsNullOrEmpty(miembro.Telefono))
                        {
                            <div><i class="bi bi-telephone"></i> @miembro.Telefono</div>
                        }
                        @if (!string.IsNullOrEmpty(miembro.Email))
                        {
                            <div><i class="bi bi-envelope"></i> @miembro.Email</div>
                        }
                        <div class="mt-1 text-muted">
                            <i class="bi bi-calendar3"></i> Desde @miembro.FechaInicio.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                    <div class="mt-2">
                        <span class="badge bg-info"><i class="bi bi-list-check"></i> @miembro.ActividadesSupervisadas.Count actividades supervisadas</span>
                    </div>
                </div>
                <div class="card-footer bg-transparent d-flex gap-1">
                    <a asp-action="Edit" asp-route-id="@miembro.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Editar</a>
                    <form asp-action="Delete" asp-route-id="@miembro.Id" method="post" onsubmit="return confirm('¿Eliminar este miembro?');">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
